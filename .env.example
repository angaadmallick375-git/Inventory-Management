# ══════════════════════════════════════════════════════════════════════════
#  InventoryOS — Environment Variables
#  Copy to .env for local/Docker use. Never commit .env to version control.
#  On Render/Railway/Vercel/Netlify — set these in the platform dashboard.
# ══════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL (local / Docker only) ────────────────────────────────────
# On hosted platforms, set DATABASE_URL directly and ignore these four.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=inventory_db
POSTGRES_HOST=db          # use "localhost" when running backend outside Docker
POSTGRES_PORT=5432

# ─── Database URL ────────────────────────────────────────────────────────
# Leave blank in local/Docker — it's built automatically from POSTGRES_* above.
# On Render/Railway: paste the hosted connection string here, e.g.:
#   DATABASE_URL=postgresql://user:pass@host:5432/inventory_db
# Note: Render gives a "postgres://" URL — the app converts it automatically.
DATABASE_URL=

# ─── CORS ────────────────────────────────────────────────────────────────
# Development default: allow all origins (*).
# Production: set to your exact frontend URL(s), comma-separated:
#   ALLOWED_ORIGINS=https://inventoryos.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# ─── Server Ports (local / Docker only) ──────────────────────────────────
# Render/Railway inject $PORT automatically — these are only for Docker/local.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ─── Vite Dev Server Proxy (local / Docker only) ─────────────────────────
# Used by vite.config.js to proxy /api/* to the backend.
# In Docker this MUST be the compose service name.
# Ignored in production builds.
VITE_BACKEND_URL=http://backend:8000

# ─── Frontend API URL ────────────────────────────────────────────────────
# Leave EMPTY in local dev / Docker → Vite proxy handles all /api/* traffic.
# Set to your deployed backend URL for Vercel / Netlify production builds:
#   VITE_API_URL=https://inventoryos-backend.onrender.com
VITE_API_URL=
